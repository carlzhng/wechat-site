# Copy this file to .env and set your own password before going live.
ADMIN_PASSWORD=your_password_here
SESSION_SECRET=random-long-string-here
PORT=3000

# Vercel only: added when you connect a Blob store to the project.
# Local dev does not need these — catalog and uploads use data/ and uploads/ instead.
# WECHAT_READ_WRITE_TOKEN=
# WECHAT_STORE_ID=
# BLOB_READ_WRITE_TOKEN=   (default name if your store is not named "wechat")
