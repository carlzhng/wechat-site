{
  "name": "wechat-store",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "build": "vite build",
    "build:vercel": "node scripts/prepare-pages.mjs && vite build",
    "build:pages": "node scripts/prepare-pages.mjs && cross-env GITHUB_PAGES=true VITE_STATIC_CATALOG=true vite build",
    "deploy:docs": "npm run build:pages && node scripts/copy-to-docs.mjs",
    "start": "cross-env NODE_ENV=production node server.js"
  },
  "dependencies": {
    "@vercel/blob": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "multer": "^2.0.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "vite": "^6.3.5"
  }
}
